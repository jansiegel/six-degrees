# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/.playwright

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.idea

# wrangler local state (Miniflare local D1, KV cache etc.)
.wrangler/

# Local SQLite files produced by ETL — large, generated artifacts
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal
*.db

# IDE / tool settings (per-dev)
.claude/
.vscode/

# MusicBrainz dump files (kept locally in ~/mb-data, but guard against accidental commits)
mbdump/
mbdump.tar.bz2
